{
  "name": "next-project",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev-all": "concurrently \"pnpm run build:sw\" \"pnpm run dev\"",
    "dev": "next dev --turbopack -p 3001",
    "build": "next build --turbopack",
    "build:sw": "esbuild app/lib/worker/firebase-messaging-sw.ts --bundle --outfile=public/firebase-messaging-sw.js --watch",
    "start": "next start",
    "lint": "biome check --no-errors-on-unmatched --write --files-ignore-unknown=true",
    "format": "biome format --no-errors-on-unmatched --write --files-ignore-unknown=true",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged",
    "commit-msg": "npx commitlint --edit $1"
  },
  "lint-staged": {
    "*": [
      "biome check --no-errors-on-unmatched --write --files-ignore-unknown=true"
    ]
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "firebase": "^12.4.0",
    "firebase-admin": "^13.5.0",
    "next": "15.5.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "esbuild": "^0.25.10",
    "lint-staged": "^16.2.3",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
